// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider               = "prisma-client"
  output                 = "../src/main/generated/prisma"
  engineType             = "client"
  moduleFormat           = "esm"
  generatedFileExtension = "ts"
  importFileExtension    = "ts"
}

datasource db {
  provider = "sqlite"
}

model Songs {
  song_id         Int               @id @default(autoincrement())
  filepath        String            @unique
  filename        String
  title           String?
  artist          String?
  album           String?
  genre           String?
  year            Int?
  duration        Float             @default(0)
  size            Int               @default(0)
  trackNumber     Int?
  coverHash       String?
  metadataLoaded  Boolean           @default(false)
  UserPreferences UserPreferences[]
  PlayHistory     PlayHistory[]
  timestamp       DateTime          @default(now())
}

model UserPreferences {
  song_id      Int           @id
  play_count   Int           @default(0)
  is_favorite  Boolean       @default(false)
  listen_later Boolean       @default(false)
  skip_count   Int           @default(0)
  bpm          Int           @default(0)
  Songs        Songs         @relation(fields: [song_id], references: [song_id])
  PlayHistory  PlayHistory[]
}

model PlayHistory {
  id        Int      @id @default(autoincrement())
  song_id   Int
  timestamp DateTime @default(now())

  Songs           Songs           @relation(fields: [song_id], references: [song_id])
  UserPreferences UserPreferences @relation(fields: [song_id], references: [song_id])
}

model Playlist {
  id           Int         @id @default(autoincrement())
  path         String      @unique
  nombre       String      @unique
  duracion     Int         @default(0)
  numElementos Int         @default(0)
  createdAt    DateTime    @default(now())
  historial    Historial[]
  totalplays   Int         @default(0)
}

model Historial {
  id         Int      @id @default(autoincrement())
  playlistId Int
  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  playedAt   DateTime @default(now())
}

model Directory {
  id   Int    @id @default(autoincrement())
  path String @unique
}
