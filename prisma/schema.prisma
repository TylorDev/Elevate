// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider               = "prisma-client"
  output                 = "../src/main/generated/prisma"
  engineType             = "client"
  moduleFormat           = "esm"
  generatedFileExtension = "ts"
  importFileExtension    = "ts"
}

datasource db {
  provider = "sqlite"
}

enum PlaybackSourceKind {
  LIBRARY
  PLAYLIST
  DIRECTORY
}

enum HistoryEntityKind {
  SONG
  PLAYLIST
  DIRECTORY
}

enum VisualizerPresetSourceMode {
  ALL
  FAVORITES
  LIST
}

enum VisualizerPlaybackSourceType {
  FAVORITES
  PLAYLIST
  DIRECTORY
}

model Songs {
  song_id           Int               @id @default(autoincrement())
  filepath          String            @unique
  filename          String
  title             String?
  artist            String?
  album             String?
  genre             String?
  year              Int?
  duration          Float             @default(0)
  size              Int               @default(0)
  trackNumber       Int?
  coverHash         String?
  metadataLoaded    Boolean           @default(false)
  UserPreferences   UserPreferences[]
  PlayHistory       PlayHistory[]
  PlaybackEvent     PlaybackEvent[]
  AppHistoryEvent   AppHistoryEvent[]
  timestamp         DateTime          @default(now())
}

model UserPreferences {
  song_id                  Int     @id
  play_count               Int     @default(0)
  is_favorite              Boolean @default(false)
  listen_later             Boolean @default(false)
  skip_count               Int     @default(0)
  short_view_count         Int     @default(0)
  long_view_count          Int     @default(0)
  long_play_seconds        Float   @default(0)
  active_listening_seconds Float   @default(0)
  consecutive_repeat_count Int     @default(0)
  bpm                      Int     @default(0)
  Songs                    Songs   @relation(fields: [song_id], references: [song_id])
}

model PlayHistory {
  id        Int      @id @default(autoincrement())
  song_id   Int
  timestamp DateTime @default(now())

  Songs Songs @relation(fields: [song_id], references: [song_id])
}

model Playlist {
  id                    Int               @id @default(autoincrement())
  path                  String            @unique
  nombre                String            @unique
  duracion              Int               @default(0)
  numElementos          Int               @default(0)
  createdAt             DateTime          @default(now())
  historial             Historial[]
  totalplays            Int               @default(0)
  PlaybackEvent         PlaybackEvent[]
  AppHistoryEvent       AppHistoryEvent[]
  customCoverMode       String?
  customCoverValue      String?
  customCoverSelection  String?
  customCoverUpdatedAt  DateTime?
}

model Historial {
  id         Int      @id @default(autoincrement())
  playlistId Int
  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  playedAt   DateTime @default(now())
}

model Directory {
  id              Int               @id @default(autoincrement())
  path            String            @unique
  parentId        Int?
  parent          Directory?        @relation("DirectoryTree", fields: [parentId], references: [id], onDelete: Cascade)
  children        Directory[]       @relation("DirectoryTree")
  totalTracks     Int               @default(0)
  totalDuration   Float             @default(0)
  lastScannedAt   DateTime?
  createdAt       DateTime          @default(now())
  PlaybackEvent   PlaybackEvent[]
  AppHistoryEvent AppHistoryEvent[]
}

model PlaybackEvent {
  id                Int                @id @default(autoincrement())
  songId            Int
  startedAt         DateTime
  endedAt           DateTime?
  secondsPlayed     Float              @default(0)
  completionRatio   Float              @default(0)
  isShortView       Boolean            @default(false)
  isLongView        Boolean            @default(false)
  sourceKind        PlaybackSourceKind
  sourcePlaylistId  Int?
  sourceDirectoryId Int?
  createdAt         DateTime           @default(now())
  song              Songs              @relation(fields: [songId], references: [song_id], onDelete: Cascade)
  sourcePlaylist    Playlist?          @relation(fields: [sourcePlaylistId], references: [id], onDelete: SetNull)
  sourceDirectory   Directory?         @relation(fields: [sourceDirectoryId], references: [id], onDelete: SetNull)
  appHistoryEvent   AppHistoryEvent?

  @@index([songId, startedAt])
  @@index([sourcePlaylistId, startedAt])
  @@index([sourceDirectoryId, startedAt])
  @@index([isShortView, startedAt])
  @@index([isLongView, startedAt])
}

model AppHistoryEvent {
  id              Int               @id @default(autoincrement())
  entityKind      HistoryEntityKind
  occurredAt      DateTime          @default(now())
  songId          Int?
  playlistId      Int?
  directoryId     Int?
  playbackEventId Int?              @unique
  song            Songs?            @relation(fields: [songId], references: [song_id], onDelete: SetNull)
  playlist        Playlist?         @relation(fields: [playlistId], references: [id], onDelete: SetNull)
  directory       Directory?        @relation(fields: [directoryId], references: [id], onDelete: SetNull)
  playbackEvent   PlaybackEvent?    @relation(fields: [playbackEventId], references: [id], onDelete: SetNull)

  @@index([occurredAt])
  @@index([entityKind, occurredAt])
}

model PlayerSession {
  id                Int     @id @default(1)
  song_id           Int?
  position_sec      Float   @default(0)
  resume_from_start Boolean @default(true)
  queue_type        String  @default("NONE")
  queue_source      String?
  queue_song_ids    String  @default("[]")
  queue_index       Int     @default(0)
}

model VisualizerSettings {
  id                 Int                        @id @default(1)
  cycleDurationMs    Int                        @default(6000)
  presetSourceMode   VisualizerPresetSourceMode @default(ALL)
  presetSourceListId String?
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
  presetSourceList   VisualizerPresetList?      @relation(fields: [presetSourceListId], references: [id], onDelete: SetNull)
}

model VisualizerPresetFavorite {
  id         Int      @id @default(autoincrement())
  presetName String   @unique
  createdAt  DateTime @default(now())
}

model VisualizerPresetList {
  id               String                         @id
  name             String
  createdAt        DateTime                       @default(now())
  updatedAt        DateTime                       @updatedAt
  items            VisualizerPresetListItem[]
  associations     VisualizerSourceAssociation[]
  settingsAsSource VisualizerSettings[]
}

model VisualizerPresetListItem {
  id         Int                  @id @default(autoincrement())
  listId     String
  presetName String
  position   Int
  createdAt  DateTime             @default(now())
  list       VisualizerPresetList @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@unique([listId, presetName])
  @@index([listId, position])
}

model VisualizerSourceAssociation {
  id         Int                          @id @default(autoincrement())
  sourceType VisualizerPlaybackSourceType
  sourceId   String
  listId     String
  createdAt  DateTime                     @default(now())
  updatedAt  DateTime                     @updatedAt
  list       VisualizerPresetList         @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@unique([sourceType, sourceId])
  @@index([listId])
}
