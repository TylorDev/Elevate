{
  "name": "elevate",
  "version": "2.0.3",
  "description": "Offline music player for Windows built by TylorDev.",
  "main": "./out/main/index.js",
  "author": {
    "name": "TylorDev",
    "url": "https://github.com/TylorDev"
  },
  "homepage": "https://github.com/TylorDev/Elevate",
  "repository": {
    "type": "git",
    "url": "https://github.com/TylorDev/Elevate.git"
  },
  "type": "module",
  "engines": {
    "node": ">=24 <25",
    "npm": ">=11"
  },
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint . --fix",
    "test": "vitest run --configLoader runner --config vitest.config.mjs",
    "test:generate": "npm run prisma:generate && npm test",
    "start": "node scripts/electron-vite.mjs preview",
    "dev": "node scripts/electron-vite.mjs dev",
    "test:main": "vitest run --configLoader runner --config vitest.config.mjs",
    "test:main:watch": "vitest --configLoader runner --config vitest.config.mjs",
    "prebuild": "node scripts/clean-build.mjs && node scripts/prepare-template-db.mjs",
    "build": "electron-vite build",
    "prisma:generate": "prisma generate",
    "postinstall": "prisma generate && electron-builder install-app-deps",
    "electron:rebuild": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "node scripts/build-win.mjs",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource/geist-sans": "^5.2.5",
    "@fontsource/inter": "^5.2.8",
    "@mui/joy": "^5.0.0-beta.52",
    "@mui/material": "^9.0.0",
    "@mui/x-charts": "^9.0.4",
    "@prisma/adapter-libsql": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@xhayper/discord-rpc": "^1.3.4",
    "axios": "^1.16.0",
    "butterchurn": "^3.0.0-beta.5",
    "butterchurn-presets": "^2.4.7",
    "cheerio": "^1.0.0-rc.12",
    "chokidar": "^5.0.0",
    "custom-electron-titlebar": "^4.2.8",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.1.7",
    "jimp": "^1.1.4",
    "lodash": "^4.17.21",
    "music-metadata": "^11.12.3",
    "prop-types": "^15.8.1",
    "react": "^19.2.5",
    "react-colorful": "^5.6.1",
    "react-dom": "^19.2.5",
    "react-icons": "^5.2.1",
    "react-player": "^2.16.0",
    "react-router-dom": "^6.25.1",
    "react-toastify": "^10.0.5",
    "react-window": "^1.8.10",
    "sharp": "^0.34.5",
    "url-metadata": "^4.1.1",
    "uuid": "^14.0.0"
  },
  "optionalDependencies": {
    "node-audio-volume-mixer": "^1.0.3"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config": "^2.1.0",
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron/rebuild": "^4.0.4",
    "@types/node": "^26.0.1",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "electron-devtools-installer": "^3.2.0",
    "electron-react-devtools": "^0.5.3",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "mock-require": "^3.0.3",
    "prettier": "^3.8.3",
    "prisma": "^6.19.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "sass": "^1.99.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.2",
    "vitest": "^4.1.9"
  }
}
