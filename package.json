{
  "name": "elevate",
  "version": "1.0.0",
  "description": "An Modern music player offline. ",
  "main": "./out/main/index.js",
  "author": "@TylorDev",
  "homepage": "https://github.com/TylorDev/Elevate",
  "type": "module",
  "engines": {
    "node": ">=24 <25",
    "npm": ">=11"
  },
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint . --fix",
    "start": "node scripts/electron-vite.mjs preview",
    "dev": "node scripts/electron-vite.mjs dev",
    "build": "electron-vite build",
    "postinstall": "prisma generate",
    "electron:rebuild": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource/inter": "^5.2.8",
    "@mui/joy": "^5.0.0-beta.52",
    "@mui/material": "^9.0.0",
    "@mui/x-charts": "^9.0.4",
    "@prisma/adapter-libsql": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "axios": "^1.16.0",
    "butterchurn": "^2.6.7",
    "butterchurn-presets": "^2.4.7",
    "cheerio": "^1.0.0-rc.12",
    "custom-electron-titlebar": "^4.2.8",
    "electron-updater": "^6.1.7",
    "jimp": "^1.1.4",
    "lodash": "^4.17.21",
    "music-metadata": "^11.12.3",
    "prop-types": "^15.8.1",
    "puppeteer": "^24.42.0",
    "react": "^19.2.5",
    "react-colorful": "^5.6.1",
    "react-devtools": "^5.3.1",
    "react-dom": "^19.2.5",
    "react-icons": "^5.2.1",
    "react-player": "^2.16.0",
    "react-router-dom": "^6.25.1",
    "react-toastify": "^10.0.5",
    "react-window": "^1.8.10",
    "sass": "^1.99.0",
    "sharp": "^0.34.5",
    "url-metadata": "^4.1.1",
    "uuid": "^10.0.0"
  },
  "optionalDependencies": {
    "node-audio-volume-mixer": "^1.0.3"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config": "^2.1.0",
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron/rebuild": "^4.0.4",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "electron-devtools-installer": "^3.2.0",
    "electron-react-devtools": "^0.5.3",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "prettier": "^3.8.3",
    "prisma": "^7.8.0",
    "react": "^19.2.5",
    "react-devtools": "^5.3.1",
    "react-dom": "^19.2.5",
    "vite": "^7.3.2"
  }
}
